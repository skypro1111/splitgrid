# ── Relay server ──────────────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
# Public origin of the relay (no trailing slash). Used to build the OAuth
# redirect URI and shown in logs. Must match the redirect URI registered in the
# WorkOS dashboard: <PUBLIC_URL>/callback
PUBLIC_URL=https://stream.splitgrid.dev

# ── WorkOS (https://dashboard.workos.com) ──────────────────────────────────────
WORKOS_API_KEY=sk_test_xxx
WORKOS_CLIENT_ID=client_xxx
# Random string >= 32 chars, used to seal the session cookie. Generate with:
#   openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=change-me-to-a-32+-char-random-string

# ── Access control ─────────────────────────────────────────────────────────────
# Optional single-user allowlist: comma-separated WorkOS user ids. When empty,
# any authenticated WorkOS user is allowed but isolated to their own room (by sub).
ALLOWED_USER_IDS=

# Per-terminal scrollback (bytes) kept in memory for late-joining viewers.
SCROLLBACK_BYTES=262144
